# Copy to .env and adjust. Never commit real secrets.

PORT=4000
NODE_ENV=development

# Auth — set a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string
# Access-token lifetime (refresh tokens last 30 days and rotate on use).
ACCESS_TTL=1h

# Social sign-in (Sign in with Apple / Google). Set these to enable the
# /api/auth/google and /api/auth/apple endpoints; unset => they return 501.
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# Data store:
#   unset / 0  -> JSON file store (server/data/db.json) — great for local dev.
#   1          -> Postgres via Prisma (set DATABASE_URL below). Use in production.
USE_PRISMA=
DATABASE_URL=postgresql://user:pass@localhost:5432/babystages?schema=public

# Email (password reset). Leave unset to log the code to the console in dev.
# In production set your provider and wire it in server/mailer.js.
EMAIL_PROVIDER=

# Billing webhook (RevenueCat) — used to verify subscription events in production.
REVENUECAT_WEBHOOK_SECRET=
