# Copy to .env (or .env.production) and adjust.

# Base URL for the API. Leave unset for web dev (uses the Vite proxy at /api).
# For mobile/native builds and the split GitHub Pages deploy, set the absolute
# hosted API base (the static frontend calls it cross-origin):
# VITE_API_BASE=https://babystages-api.onrender.com/api
VITE_API_BASE=

# Public base path the app is served from. "/" for local/root/custom-domain;
# "/<repo>/" for a GitHub Pages project site, e.g. "/babystages/".
# In CI this is set by the Pages workflow — see docs/SPLIT_DEPLOY.md.
VITE_BASE=

# RevenueCat public SDK keys (client). Used by the native purchase flow.
VITE_REVENUECAT_IOS_KEY=
VITE_REVENUECAT_ANDROID_KEY=
